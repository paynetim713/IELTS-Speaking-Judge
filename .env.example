# Copy to .env (gitignored) and set the values. webapp.py reads these via os.environ.
# Only LLM_PROVIDER and either Ollama/Groq creds are strictly needed; the rest have safe defaults.

# ── App mode ─────────────────────────────────────────────────────────
# dev  — relaxed: file-backed secret key, cookie secure=false
# prod — strict: SECRET_KEY must come from env, cookie SameSite=None;Secure
IELTS_ENV=dev

# ── LLM ──────────────────────────────────────────────────────────────
# ollama (local) / groq (free 70B) / deepseek (paid, but better at scoring)
LLM_PROVIDER=ollama
# Per-turn override: pick deepseek here to route ONLY the band-scoring turn
# to DeepSeek R1 while keeping examiner replies on the free tier.
LLM_FEEDBACK_PROVIDER=
# Ollama only
OLLAMA_URL=http://localhost:11434
# Groq (https://console.groq.com)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
# DeepSeek (https://platform.deepseek.com — recommended for feedback only)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# Override model names if you want a different tier
LLM_EXAMINER_MODEL=
LLM_FEEDBACK_MODEL=

# ── Database ─────────────────────────────────────────────────────────
# Unset → sqlite at sessions.db (local). Set to postgres URL → Supabase / Render PG.
# Supabase: Settings → Database → Connection string → URI (use the pooled 6543 port for serverless)
DATABASE_URL=

# ── Session cookie ───────────────────────────────────────────────────
# Required in prod. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
IELTS_SECRET_KEY=

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins for prod
# (e.g. https://my-app.pages.dev,https://my-domain.com)
CORS_ORIGINS=
